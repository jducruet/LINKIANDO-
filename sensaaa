<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Senza — Mockup iPhone (móvil)</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=Archivo:ital,wght@0,800;1,800&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#ffffff; --bg-2:#f4f6f7; --surface:#ffffff; --surface-2:#eef1f3;
    --line:#e3e8ea; --line-soft:#eef1f2;
    --text:#0f1517; --muted:#5d696f; --muted-2:#9aa6ac;
    --teal:#ff3b00; --teal-deep:#e23410; --teal-glow:rgba(255,59,0,.13); --blue:#0077ff; --blue-glow:rgba(0,119,255,.13);
    --chrome:#5d696f; --radius:16px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{
    font-family:'Inter',system-ui,sans-serif;
    background:radial-gradient(1200px 800px at 50% -10%, #1b2226, #0a0d0e 70%);
    min-height:100vh;display:flex;flex-direction:column;align-items:center;
    padding:48px 16px;color:var(--text);
  }
  .stage-label{font-family:'Space Grotesk';font-size:13px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted-2);margin-bottom:26px}

  /* ============ IPHONE FRAME ============ */
  .phone{
    position:relative;width:402px;height:858px;flex-shrink:0;
    background:linear-gradient(150deg,#3a4045,#22272b 40%,#2c3236 70%,#1a1e21);
    border-radius:60px;padding:13px;
    box-shadow:
      0 0 0 2px #44494d,
      0 2px 4px rgba(255,255,255,.18) inset,
      0 50px 90px -30px rgba(0,0,0,.8),
      0 12px 30px rgba(0,0,0,.5);
  }
  /* side buttons */
  .phone::before{ /* power */
    content:"";position:absolute;right:-3px;top:210px;width:3px;height:92px;border-radius:0 3px 3px 0;
    background:linear-gradient(#3a4045,#23282b);
  }
  .phone .btns{position:absolute;left:-3px;top:170px}
  .phone .btns i{display:block;width:3px;border-radius:3px 0 0 3px;background:linear-gradient(#3a4045,#23282b);margin-bottom:18px}
  .phone .btns i.silent{height:30px;top:0}
  .phone .btns i.up{height:60px}
  .phone .btns i.down{height:60px}

  .screen{
    position:relative;width:100%;height:100%;border-radius:48px;overflow:hidden;
    background:var(--bg);
  }
  .island{
    position:absolute;top:13px;left:50%;transform:translateX(-50%);
    width:122px;height:34px;background:#000;border-radius:20px;z-index:40;
  }
  .statusbar{
    position:absolute;top:0;left:0;right:0;height:52px;z-index:30;background:#fff;
    display:flex;align-items:center;justify-content:space-between;
    padding:18px 30px 0;font-family:'Space Grotesk';font-size:14px;font-weight:600;
    pointer-events:none;
  }
  .statusbar .icons{display:flex;align-items:center;gap:6px}
  .bars{display:flex;align-items:flex-end;gap:2px;height:11px}
  .bars span{width:3px;background:var(--text);border-radius:1px}
  .bars span:nth-child(1){height:4px}.bars span:nth-child(2){height:6px}
  .bars span:nth-child(3){height:8px}.bars span:nth-child(4){height:11px}
  .wifi{width:15px;height:11px}
  .batt{width:23px;height:12px;border:1.4px solid var(--text);border-radius:3px;position:relative;padding:1.5px}
  .batt::after{content:"";position:absolute;right:-3px;top:3px;width:2px;height:5px;background:var(--text);border-radius:0 2px 2px 0}
  .batt b{display:block;height:100%;width:78%;background:var(--text);border-radius:1px}

  /* scroll area */
  .scroll{
    position:absolute;inset:0;overflow-y:auto;overflow-x:hidden;
    padding-top:52px;padding-bottom:92px;-webkit-overflow-scrolling:touch;scrollbar-width:none;
  }
  .scroll::-webkit-scrollbar{display:none}
  .home-ind{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);width:134px;height:5px;border-radius:3px;background:rgba(0,0,0,.28);z-index:30}

  /* ============ MOBILE PAGE ============ */
  .m-header{
    position:sticky;top:0;z-index:20;background:#fff;
    display:flex;align-items:center;justify-content:space-between;padding:12px 18px;border-bottom:1px solid var(--line-soft);
  }
  .brand{display:flex;align-items:center;gap:8px;font-family:'Space Grotesk';font-weight:700;font-size:18px;letter-spacing:.04em}
  .brand .mark{width:26px;height:26px;border-radius:7px;background:linear-gradient(135deg,var(--teal),var(--teal-deep));display:grid;place-items:center;color:#06110f;font-size:14px}
  .brand .logo{height:27px;width:auto;display:block}
  .m-footer .brand .logo{height:30px}
  .burger{background:none;border:0;color:var(--text);font-size:20px}

  .hero{
    padding:16px 20px;position:relative;overflow:hidden;min-height:150px;
    display:flex;flex-direction:column;justify-content:center;
    background-image:url('data:image/jpeg;base64,');
    background-size:cover;background-position:62% center;background-repeat:no-repeat;
  }
  .hero::before{content:"";position:absolute;inset:0;background:linear-gradient(95deg,rgba(6,9,11,.8) 0%,rgba(6,9,11,.45) 24%,rgba(6,9,11,.12) 44%,rgba(6,9,11,0) 60%),linear-gradient(180deg,transparent 64%,rgba(6,9,11,.28) 100%);pointer-events:none}
  .hero>*{position:relative}
  .eyebrow{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:#ff3b00;font-weight:600;display:inline-flex;align-items:center;gap:7px;margin-bottom:14px}
  .eyebrow::before{content:"";width:20px;height:1px;background:#ff3b00}
  .hero h1{font-family:'Archivo';font-weight:800;font-size:32px;line-height:.92;letter-spacing:-.02em;color:#fff;text-shadow:0 2px 18px rgba(0,0,0,.75),0 1px 3px rgba(0,0,0,.55)}
  .shine{background:linear-gradient(100deg,#fff 38%,#ff3b00 50%,#fff 62%);background-size:280% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;animation:sweep 5s ease-in-out infinite}
  .impec{color:#ff3b00;font-style:italic;font-weight:800}
  .hero-img{display:block;width:100%;height:auto}
  .hero .hrule{display:block;width:42px;height:3px;background:#ff3b00;border-radius:2px;margin:12px 0 11px}
  @keyframes sweep{0%,72%{background-position:200% 0}88%,100%{background-position:-40% 0}}
  .hero p{color:#fff;font-size:12px;font-weight:500;line-height:1.4;margin-top:9px;max-width:none;text-shadow:0 1px 12px rgba(0,0,0,.85),0 1px 3px rgba(0,0,0,.6)}
  .hero .cta{margin-top:20px;display:flex;flex-direction:column;gap:12px}
  .btn{font-family:'Inter';font-weight:600;font-size:15px;border-radius:999px;padding:14px;text-align:center;border:1px solid transparent;cursor:pointer;display:block;text-decoration:none}
  .btn-primary{background:var(--teal);color:#06110f}
  .hero .anchor{color:rgba(255,255,255,.72);font-size:13px;margin-top:4px;text-align:center}
  .hero .anchor b{color:#fff;font-family:'Space Grotesk'}

  .planes{padding:8px 18px 30px}
  .sec-kicker{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--teal);font-weight:600;text-align:center}
  .sec-h{font-family:'Archivo';font-weight:800;font-size:18px;letter-spacing:-.02em;text-align:center;margin:14px 0 24px;color:var(--text);line-height:1.15}

  .toggle{display:grid;grid-template-columns:1fr 1fr;background:#eef1f3;border-radius:999px;padding:3px;width:max-content;max-width:100%;margin:0 auto 22px}
  .toggle button{width:100%;border:0;background:transparent;color:var(--muted);font-family:'Inter';padding:1px 16px;cursor:pointer;border-radius:999px;transition:background .2s,color .2s,box-shadow .2s;display:flex;flex-direction:column;align-items:center;gap:0;line-height:1.05}
  .toggle button + button{border-left:0}
  .toggle .bt-main{font-size:12px;font-weight:600;white-space:nowrap}
  .toggle .bt-sub{font-size:8.5px;font-weight:700;opacity:.9;white-space:nowrap}
  .toggle button.active{color:#fff;background:var(--teal);box-shadow:0 3px 9px rgba(255,59,0,.35)}
  .toggle .pill{display:none}
  .toggle.multi .pill{transform:translateX(100%)}

  .stepper{display:none;align-items:center;justify-content:center;gap:18px;background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:10px;margin-bottom:16px}
  .toggle.multi ~ .stepper{display:flex}
  .stepper button{width:32px;height:32px;border-radius:50%;border:1px solid var(--line);background:var(--bg-2);color:var(--text);font-size:19px;cursor:pointer}
  .stepper .c{font-family:'Space Grotesk';font-weight:700;font-size:17px}
  .stepper .c span{color:var(--muted);font-size:12px;font-weight:500;font-family:'Inter'}

  /* ===== HORIZONTAL STACKED CARDS ===== */
  .cards{display:flex;flex-direction:column;gap:12px;margin-top:18px}
  .hcard-wrap{position:relative}
  .ribbon{position:absolute;top:-9px;left:14px;z-index:4;font-family:'Archivo';font-weight:800;font-size:8.5px;letter-spacing:.07em;text-transform:uppercase;color:#fff;background:var(--teal);padding:3px 11px;border-radius:999px;box-shadow:0 3px 8px rgba(255,59,0,.3)}
  .hcard{
    background:var(--surface);border:1.5px solid var(--bor,var(--line));border-radius:16px;
    overflow:hidden;transition:box-shadow .2s;
    box-shadow:0 1px 2px rgba(15,21,23,.04),0 8px 20px -12px rgba(15,21,23,.1);
  }
  .hcard-head{display:flex;align-items:center;gap:10px;padding:6px 14px;cursor:pointer}
  .hc-col1{flex:1.05;min-width:0}
  .hc-name{font-family:'Archivo';font-weight:800;font-size:11.5px;letter-spacing:.02em;text-transform:uppercase;color:var(--acc)}
  .hc-price{display:flex;align-items:baseline;gap:3px;margin-top:1px;flex-wrap:wrap}
  .hc-price .amt{font-family:'Archivo';font-weight:800;font-size:23px;line-height:1;color:#15202a}
  .hc-price .per{font-size:10.5px;color:var(--muted)}
  .hc-ulim{font-family:'Inter';font-weight:600;font-size:9.5px;color:#3a464d;margin-top:3px;display:flex;align-items:center;gap:4px;white-space:nowrap}
  .hc-ulim::before{content:"\221E";color:var(--teal);font-size:13px;font-weight:700;line-height:1}
  .hc-div{width:1px;align-self:stretch;background:var(--line);margin:4px 8px}
  .hc-col2{flex:.72;text-align:center;min-width:0}
  .hc-col2 .lbl{font-size:8px;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);line-height:1.25;font-weight:700}
  .hc-col2 .v{font-family:'Archivo';font-weight:800;font-size:17px;color:#15202a;margin-top:1px}
  .hc-col3{flex:1;text-align:center;min-width:0}
  .hc-col3 .be{font-family:'Inter';font-weight:600;font-size:11.5px;line-height:1.25;color:var(--sep)}
  .chev{color:var(--text);font-size:11px;transition:transform .25s;flex-shrink:0}
  .hcard.open .chev{transform:rotate(180deg)}

  .hcard-body{max-height:0;overflow:hidden;transition:max-height .35s ease}
  .hcard.open .hcard-body{max-height:560px}
  .body-inner{padding:4px 14px 16px;border-top:1px solid var(--line-soft)}
  .feats{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:8px 12px;margin-top:14px}
  .feats li{display:flex;align-items:center;gap:7px;font-size:12px}
  .feats li.off{color:var(--muted-2)}
  .ck{width:15px;height:15px;border-radius:50%;display:grid;place-items:center;font-size:9px;flex-shrink:0}
  .ck.on{background:var(--blue-glow);color:var(--blue)}.ck.no{background:var(--surface-2);color:var(--muted-2)}
  .addon{font-size:11.5px;color:var(--muted);margin-top:13px;padding-top:12px;border-top:1px dashed var(--line)}
  .addon b{color:var(--text)}
  .hcard .btn{margin-top:14px;font-size:14px;padding:12px;background:var(--teal);color:#0d1011}

  .model-note{font-size:10.5px;color:var(--muted-2);text-align:center;margin-top:14px}

  .m-footer{padding:26px 20px;border-top:1px solid var(--line-soft);margin-top:10px}
  .m-footer .brand{font-size:16px;margin-bottom:14px}
  .m-footer a{display:block;color:var(--muted);font-size:13px;padding:6px 0;text-decoration:none}
  .legal{color:var(--muted-2);font-size:11px;margin-top:14px;padding-bottom:60px}

  /* ===== SECCIONES HOME ===== */
  .sec{padding:34px 20px}
  .sec .kick{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--teal);font-weight:700;text-align:center}
  .sec h2{font-family:'Archivo';font-weight:800;font-size:22px;letter-spacing:-.02em;text-align:center;margin-top:8px}
  .sec .sub2{color:var(--muted);font-size:13.5px;text-align:center;margin-top:8px;line-height:1.5}
  .trust{display:flex;justify-content:center;gap:16px;flex-wrap:wrap;background:var(--text);color:#fff;padding:13px 16px}
  .trust span{font-size:11px;font-weight:600;display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
  .trust span::before{content:"\2713";color:var(--teal);font-weight:800}
  .steps{display:flex;flex-direction:column;gap:12px;margin-top:22px}
  .step{display:flex;gap:14px;align-items:flex-start;background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:15px}
  .step .n{flex-shrink:0;width:34px;height:34px;border-radius:10px;background:var(--teal-glow);color:var(--teal);font-family:'Archivo';font-weight:800;font-size:17px;display:grid;place-items:center}
  .step .st-t{font-family:'Space Grotesk';font-weight:600;font-size:15px}
  .step .st-d{color:var(--muted);font-size:13px;margin-top:3px;line-height:1.45}
  .loc-card{margin-top:20px;border:1px solid var(--line);border-radius:16px;overflow:hidden}
  .map{height:158px;position:relative;background:repeating-linear-gradient(0deg,transparent 0 22px,rgba(0,119,255,.06) 22px 23px),repeating-linear-gradient(90deg,transparent 0 22px,rgba(0,119,255,.06) 22px 23px),linear-gradient(135deg,#eef3f6,#e3eaef)}
  .map .road{position:absolute;left:-10%;right:-10%;top:54%;height:14px;background:#fff;border-top:1px solid #d4dde2;border-bottom:1px solid #d4dde2;transform:rotate(-7deg)}
  .map .road2{position:absolute;top:-10%;bottom:-10%;left:38%;width:12px;background:#fff;border-left:1px solid #d4dde2;border-right:1px solid #d4dde2;transform:rotate(6deg)}
  .map .pin{position:absolute;left:50%;top:46%;transform:translate(-50%,-100%) rotate(-45deg);width:26px;height:26px;background:var(--teal);border-radius:50% 50% 50% 0;box-shadow:0 6px 14px rgba(255,59,0,.4)}
  .map .pin::after{content:"";position:absolute;inset:7px;background:#fff;border-radius:50%}
  .loc-info{padding:16px;display:flex;flex-direction:column;gap:5px}
  .loc-info .addr{font-family:'Space Grotesk';font-weight:600;font-size:15px}
  .loc-info .meta{color:var(--muted);font-size:13px}
  .loc-info .meta b{color:var(--teal)}
  .btn-line{margin-top:8px;align-self:flex-start;border:1.5px solid var(--teal);color:var(--teal);font-weight:600;font-size:13.5px;padding:9px 16px;border-radius:999px;text-decoration:none}
  .rating{display:flex;flex-direction:column;align-items:center;gap:3px;margin-top:18px}
  .rating .score{font-family:'Archivo';font-weight:800;font-size:30px}
  .stars{color:var(--teal);font-size:16px;letter-spacing:2px}
  .rating .count{color:var(--muted);font-size:12.5px}
  .revs{display:flex;flex-direction:column;gap:12px;margin-top:18px}
  .rev{background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:15px}
  .rev .rv-top{display:flex;align-items:center;gap:10px;margin-bottom:8px}
  .rev .av{width:30px;height:30px;border-radius:50%;background:var(--blue-glow);color:var(--blue);font-weight:700;font-size:13px;display:grid;place-items:center;font-family:'Space Grotesk'}
  .rev .rv-name{font-weight:600;font-size:13.5px}
  .rev .rv-stars{color:var(--teal);font-size:11px;letter-spacing:1px}
  .rev p{color:var(--muted);font-size:13px;line-height:1.5}
  .faq2{margin-top:16px;border-top:1px solid var(--line-soft)}
  .q2{border-bottom:1px solid var(--line-soft)}
  .q2 button{width:100%;background:none;border:0;text-align:left;cursor:pointer;font-family:'Space Grotesk';font-weight:600;font-size:14.5px;color:var(--text);padding:16px 2px;display:flex;justify-content:space-between;align-items:center;gap:12px}
  .q2 .cx{color:var(--teal);transition:transform .25s;font-size:16px;flex-shrink:0;line-height:1}
  .q2.open .cx{transform:rotate(45deg)}
  .q2 .ax{max-height:0;overflow:hidden;transition:max-height .3s ease;color:var(--muted);font-size:13.5px;line-height:1.55}
  .q2 .ax p{padding:0 2px 16px}
  .closer{background:var(--text);color:#fff;padding:38px 22px;text-align:center}
  .closer h2{font-family:'Archivo';font-weight:800;font-size:23px;line-height:1.12;letter-spacing:-.02em}
  .closer .price{color:var(--teal)}
  .closer .btn-go{display:inline-block;margin-top:18px;background:var(--teal);color:#0d1011;font-weight:700;font-size:15px;padding:14px 30px;border-radius:999px;text-decoration:none}
  .closer small{display:block;color:rgba(255,255,255,.55);font-size:12px;margin-top:12px}
  .sticky-cta{position:absolute;left:0;right:0;bottom:0;z-index:25;background:rgba(255,255,255,.97);backdrop-filter:blur(8px);border-top:1px solid var(--line);box-shadow:0 -6px 20px rgba(15,21,23,.07);padding:12px 16px 20px;display:flex;align-items:center;gap:12px}
  .sticky-cta .sc-txt{flex:1;line-height:1.15}
  .sticky-cta .sc-1{font-family:'Space Grotesk';font-weight:700;font-size:13px}
  .sticky-cta .sc-2{color:var(--muted);font-size:11px}
  .sticky-cta a{background:var(--teal);color:#0d1011;font-weight:700;font-size:14px;padding:12px 22px;border-radius:999px;text-decoration:none;white-space:nowrap}

  /* comparacion */
  .vs{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:20px}
  .vs-col{border-radius:14px;padding:16px 13px;border:1px solid var(--line)}
  .vs-col.good{background:linear-gradient(160deg,var(--teal-glow),var(--surface) 62%);border-color:var(--teal)}
  .vs-h{font-family:'Space Grotesk';font-weight:600;font-size:12.5px;margin-bottom:11px}
  .vs-col.good .vs-h{color:var(--teal)}
  .vs-col ul{list-style:none;display:flex;flex-direction:column;gap:9px}
  .vs-col li{font-size:12px;line-height:1.35;padding-left:19px;position:relative;color:var(--muted)}
  .vs-col.bad li::before{content:"\2715";position:absolute;left:0;color:#bcc5ca;font-weight:700}
  .vs-col.good li{color:var(--text)}
  .vs-col.good li::before{content:"\2713";position:absolute;left:0;color:var(--teal);font-weight:700}
  .loyalty-btn{display:inline-block;margin:18px auto 0;border:1.5px solid var(--teal);color:var(--teal);font-weight:600;font-size:13.5px;padding:10px 18px;border-radius:999px;text-decoration:none}
  .freq-card{display:block;width:100%;max-width:250px;margin:20px auto 6px;border-radius:16px;box-shadow:0 12px 34px -10px rgba(15,21,23,.4)}
  .center{text-align:center}
  .mode-msg{text-align:center;margin:0 auto 18px;max-width:34ch}
  .mode-msg .mm-1{display:block;font-family:'Space Grotesk';font-weight:700;font-size:16px;letter-spacing:-.01em;line-height:1.18;color:#1d262c}
  .mode-msg .mm-2{display:block;font-size:11px;line-height:1.3;color:#5d696f;margin-top:0}
  .mode-msg .mm-3{display:block;font-size:10.5px;line-height:1.2;color:#9aa6ac;margin-top:0}
  .isteps{display:flex;flex-direction:column;align-items:center;gap:22px;margin-top:24px}
  .istep{display:flex;flex-direction:column;align-items:center;gap:10px;text-align:center}
  .istep img{height:62px;width:auto;display:block}
  .istep-t{font-family:'Space Grotesk';font-weight:600;font-size:15px;color:var(--text)}
  .istep img.big{height:82px}
  .istep-s{font-family:'Inter';font-weight:500;font-size:11px;color:var(--muted);margin-top:-6px;max-width:170px}
  .vid{position:relative;width:100%;max-width:300px;margin:30px auto 0;aspect-ratio:16/9;border-radius:16px;overflow:hidden;background:linear-gradient(135deg,#1d2731,#0f1517);display:grid;place-items:center;cursor:pointer;box-shadow:0 14px 34px -12px rgba(15,21,23,.5)}
  .vid::after{content:'';position:absolute;inset:0;background:radial-gradient(120% 120% at 70% 20%,rgba(255,59,0,.16),transparent 55%)}
  .vid-play{position:relative;z-index:2;width:56px;height:56px;border-radius:50%;background:var(--teal);color:#fff;display:grid;place-items:center;font-size:18px;padding-left:4px;box-shadow:0 8px 20px rgba(255,59,0,.45)}
  .vid-label{position:absolute;z-index:2;bottom:12px;left:14px;color:#fff;font-family:'Inter';font-weight:600;font-size:12px;letter-spacing:.01em;opacity:.95}

  /* ===== VERSIÓN SIN MARCO · PÁGINA MÓVIL REAL ===== */
  body{background:#fff!important;padding:0!important;display:block!important;min-height:auto!important}
  .stage-label,.island,.statusbar,.home-ind,.phone .btns{display:none!important}
  .phone::before{display:none!important}
  .phone{position:relative!important;width:100%!important;max-width:480px!important;height:auto!important;margin:0 auto!important;padding:0!important;border-radius:0!important;box-shadow:none!important;background:#fff!important}
  .screen{position:relative!important;width:100%!important;height:auto!important;min-height:100vh!important;border-radius:0!important;overflow:visible!important}
  .scroll{position:static!important;inset:auto!important;height:auto!important;overflow:visible!important;padding-top:0!important;padding-bottom:88px!important}
  .sticky-cta{position:fixed!important;left:50%!important;right:auto!important;transform:translateX(-50%)!important;width:100%!important;max-width:480px!important}
</style>
</head>
<body>
  <div class="stage-label">Senza · vista móvil</div>

  <div class="phone">
    <div class="btns"><i class="silent"></i><i class="up"></i><i class="down"></i></div>
    <div class="screen">
      <div class="island"></div>
      <div class="statusbar">
        <span>9:41</span>
        <div class="icons">
          <div class="bars"><span></span><span></span><span></span><span></span></div>
          <svg class="wifi" viewBox="0 0 16 12" fill="none"><path d="M8 10.5l1.6-1.7a2.3 2.3 0 00-3.2 0L8 10.5zM4.8 7.3a4.6 4.6 0 016.4 0l1.1-1.2a6.2 6.2 0 00-8.6 0l1.1 1.2zM2.6 5a7.8 7.8 0 0110.8 0l1.1-1.2a9.4 9.4 0 00-13 0L2.6 5z" fill="#0f1517"/></svg>
          <div class="batt"><b></b></div>
        </div>
      </div>

      <div class="scroll">
        <!-- header -->
        <div class="m-header">
          <a class="brand"><img class="logo" src="data:image/png;base64," alt="Senza Car Wash"></a>
          <button class="burger">☰</button>
        </div>

        <!-- hero -->
        <div class="hero">
          <h1>Tu Auto<br><span class="impec">Impecable,</span><br>Siempre.</h1>
          <span class="hrule"></span>
          <p>Deja de pagar por lavado.<br>Suscríbete y ahorra lavando ilimitadamente.</p>
        </div>

        <!-- planes -->
        <div class="planes" id="planes">
          <div class="sec-h">Lavadas ilimitadas <span style="color:var(--teal)">desde $25/mes</span></div>

          <div class="toggle" id="toggle">
            <span class="pill"></span>
            <button class="active" data-mode="personal"><span class="bt-main">Personal</span><span class="bt-sub">un vehículo</span></button>
            <button data-mode="multi"><span class="bt-main">Multi-Vehículo</span><span class="bt-sub">familia, amigos, grupos</span></button>
          </div>

          <p class="mode-msg" id="modeMsg"><span class="mm-1">Elige el nivel de cuidado para tu auto</span><span class="mm-2">Mientras más alto el plan,<br>más productos para cuidar la pintura.</span></p>

          <div class="stepper">
            <button id="dec">−</button>
            <div class="c"><span id="vc">2</span> <span>vehículos</span></div>
            <button id="inc">+</button>
          </div>

          <div class="cards" id="cards"></div>
          <div class="model-note" id="note" style="display:none">Modelo multi de ejemplo · pásame tu tabla real para clavar los números.</div>
        </div>

        <!-- footer -->
        <!-- banda de confianza -->
        <div class="trust"><span>Sin contrato</span><span>Cancela cuando quieras</span><span>Sin penalidad</span></div>

        <!-- como funciona -->
        <section class="sec">
          <div class="kick">Cómo funciona</div>
          <h2>Así de fácil</h2>
          <p class="sub2">Empieza hoy, en tres pasos.</p>
          <div class="isteps">
            <div class="istep"><img class="big" src="data:image/png;base64," alt="Suscríbete en línea"><div class="istep-t">Suscríbete en línea</div><div class="istep-s">con tu tarjeta de crédito</div></div>
            <div class="istep"><img src="data:image/png;base64," alt="Registramos el auto"><div class="istep-t">Registramos el auto</div><div class="istep-s">tu placa te identifica</div></div>
            <div class="istep"><img src="data:image/png;base64," alt="Lava todos los días"><div class="istep-t">Lava todos los días</div><div class="istep-s">disfruta lavadas ilimitadas</div></div>
          </div>
          <div class="vid">
            <div class="vid-play">&#9654;</div>
            <div class="vid-label">Míralo en acción · 30s</div>
          </div>
        </section>

        <!-- ubicacion -->
        <section class="sec" style="background:var(--bg-2)">
          <div class="kick">Ubicación</div>
          <h2>Encuéntranos</h2>
          <p class="sub2">A un par de minutos de ti.</p>
          <div class="loc-card">
            <div class="map"><div class="road"></div><div class="road2"></div><div class="pin"></div></div>
            <div class="loc-info">
              <div class="addr">Av. Principal, Costa del Este</div>
              <div class="meta">Ciudad de Panamá</div>
              <div class="meta">Lun–Dom · <b>7:00 a.m. – 8:00 p.m.</b></div>
              <a class="btn-line" href="#">Cómo llegar →</a>
            </div>
          </div>
        </section>

        <!-- reseñas -->
        <section class="sec">
          <div class="kick">Lo que dicen</div>
          <h2>Miembros felices</h2>
          <div class="rating"><div class="stars">★★★★★</div><div class="score">4.9</div><div class="count">320+ reseñas en Google</div></div>
          <div class="revs">
            <div class="rev"><div class="rv-top"><div class="av">JM</div><div><div class="rv-name">José M.</div><div class="rv-stars">★★★★★</div></div></div><p>"Lavo el carro dos veces por semana y ya se pagó solo. El servicio es rapidísimo."</p></div>
            <div class="rev"><div class="rv-top"><div class="av">AR</div><div><div class="rv-name">Ana R.</div><div class="rv-stars">★★★★★</div></div></div><p>"Tengo el plan multi para los dos autos de la casa. Comodísimo y sin contratos raros."</p></div>
          </div>
        </section>

        <!-- faq -->
        <section class="sec" style="background:var(--bg-2)">
          <div class="kick">Dudas</div>
          <h2>Preguntas frecuentes</h2>
          <div class="faq2" id="faq2"></div>
        </section>

        <!-- valor: vs pago suelto -->
        <section class="sec">
          <div class="kick">Por qué membresía</div>
          <h2>Las cuentas claras</h2>
          <div class="vs">
            <div class="vs-col bad">
              <div class="vs-h">Pagando por lavado</div>
              <ul>
                <li>$9 a $25 cada vez que vas</li>
                <li>Lo piensas dos veces antes de ir</li>
                <li>Auto sucio entre lavadas</li>
              </ul>
            </div>
            <div class="vs-col good">
              <div class="vs-h">Con membresía Senza</div>
              <ul>
                <li>Desde $25 al mes, ilimitado</li>
                <li>Lavas cuando quieras, sin pensarlo</li>
                <li>Auto impecable, siempre</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- cliente frecuente -->
        <section class="sec" style="background:var(--bg-2)">
          <div class="kick">Cliente Frecuente</div>
          <h2>Lavar frecuente también tiene ventajas</h2>
          <p class="sub2">Descarga tu tarjeta y recibe un lavado gratis por cada 8 lavadas.</p>
          <div class="center"><img class="freq-card" src="data:image/jpeg;base64," alt="Tarjeta Cliente Frecuente Senza"></div>
          <div class="center"><a class="loyalty-btn" href="#">Descargar mi tarjeta →</a></div>
        </section>

        <!-- cierre -->
        <section class="closer">
          <h2>Tu auto impecable,<br>desde <span class="price">$25/mes</span></h2>
          <a class="btn-go" href="#planes">Suscribirme →</a>
          <small>Sin contrato · cancela cuando quieras</small>
        </section>

        <div class="m-footer">
          <a class="brand"><img class="logo" src="data:image/png;base64," alt="Senza Car Wash"></a>
          <a href="#">Membresías</a>
          <a href="#">Ubicación</a>
          <a href="#">Administrar membresías</a>
          <a href="#">Loyalty Card</a>
          <a href="#">Trabaja con nosotros</a>
          <div class="legal">© 2026 Senza Car Wash · Panamá. Precios + ITBMS.</div>
        </div>
      </div>

      <div class="sticky-cta"><div class="sc-txt"><div class="sc-1">Lavados ilimitados</div><div class="sc-2">desde $25/mes · sin contrato</div></div><a href="#planes">Suscribirme</a></div>
      <div class="home-ind"></div>
    </div>
  </div>

<script>
  const plans = [
    { name:'Ultimate', price:39, single:25, be:2, addCar:30, acc:'#c2912b', bor:'#c2912b', sep:'#ff3b00', tag:'Más recomendado',
      feats:[['Lavado',1],['Secado',1],['Ruedas',1],['Espuma activa',1],['Chasis',1],['Supreme Wax',1],['Ultimate Shine',1]],
      addon:'<b>Incluido:</b> 2 limpiezas + aspirado interior/mes por vehículo · adicionales $5/visita.' },
    { name:'Supreme', price:34, single:20, be:2, addCar:28, acc:'#ff3b00', bor:'#ff3b00', sep:'#ff3b00',
      feats:[['Lavado',1],['Secado',1],['Ruedas',1],['Espuma activa',1],['Chasis',1],['Supreme Wax',1],['Ultimate Shine',0]],
      addon:'Limpieza + aspirado interior: <b>$5</b> por visita.' },
    { name:'Deluxe', price:30, single:13, be:3, addCar:26, acc:'#0077ff', bor:'#0077ff', sep:'#ff3b00',
      feats:[['Lavado',1],['Secado',1],['Ruedas',1],['Espuma activa',1],['Chasis',0],['Supreme Wax',0],['Ultimate Shine',0]],
      addon:'Limpieza + aspirado interior: <b>$5</b> por visita.' },
    { name:'Basic', price:25, single:9, be:3, addCar:24, acc:'#5d6b73', bor:'#b3bcc1', sep:'#ff3b00',
      feats:[['Lavado',1],['Secado',1],['Ruedas',0],['Espuma activa',0],['Chasis',0],['Supreme Wax',0],['Ultimate Shine',0]],
      addon:'Limpieza + aspirado interior: <b>$5</b> por visita.' }
  ];

  let mode='personal', vehicles=2;
  const money=n=>'$'+(Number.isInteger(n)?n:n.toFixed(2));
  const perAuto=p=>(p.price+(vehicles-1)*p.addCar)/vehicles;

  function render(){
    const multi = mode==='multi';
    document.getElementById('cards').innerHTML = plans.map((p,i)=>{
      const main = multi?perAuto(p):p.price;
      const feats = p.feats.map(([l,on])=>`<li class="${on?'':'off'}"><span class="ck ${on?'on':'no'}">${on?'✓':'—'}</span>${l}</li>`).join('');
      return `
      <div class="hcard-wrap">
        ${p.tag?`<span class="ribbon">${p.tag}</span>`:''}
        <div class="hcard" style="--acc:${p.acc};--bor:${p.bor};--sep:${p.sep}">
        <div class="hcard-head" data-i="${i}">
          <div class="hc-col1">
            <div class="hc-name">${p.name}</div>
            <div class="hc-price"><span class="amt">${money(main)}</span><span class="per">/mes${multi?' · auto':''} + ITBMS</span></div>
            <div class="hc-ulim">Lavados ilimitados</div>
          </div>
          <div class="hc-div"></div>
          <div class="hc-col2">
            <div class="lbl">Lavado<br>individual</div>
            <div class="v">${money(p.single)}</div>
          </div>
          <div class="hc-col3">
            <div class="be">Se paga en<br>solo ${p.be} lavados</div>
          </div>
          <span class="chev">▼</span>
        </div>
        <div class="hcard-body">
          <div class="body-inner">
            <ul class="feats">${feats}</ul>
            <div class="addon">${p.addon}</div>
            <a class="btn" href="#">${multi?'Activar multi →':'Suscribirme →'}</a>
          </div>
        </div>
        </div>
      </div>`;
    }).join('');

    document.querySelectorAll('.hcard-head').forEach(h=>{
      h.addEventListener('click',()=>h.parentElement.classList.toggle('open'));
    });
  }

  function setMode(m){
    mode=m;
    document.getElementById('toggle').classList.toggle('multi', m==='multi');
    document.querySelectorAll('#toggle button').forEach(b=>b.classList.toggle('active', b.dataset.mode===m));
    document.getElementById('note').style.display = m==='multi'?'block':'none';
    document.getElementById('modeMsg').innerHTML = m==='multi'
      ? '<span class="mm-1">Hasta 5 vehículos por grupo</span><span class="mm-2">tú decides quién ahorra contigo.</span><span class="mm-3">familia, amigos, vecinos.</span>'
      : '<span class="mm-1">Elige el nivel de cuidado para tu auto</span><span class="mm-2">Mientras más alto el plan,<br>más productos para cuidar la pintura.</span>';
    render();
  }
  document.querySelectorAll('#toggle button').forEach(b=>b.addEventListener('click',()=>setMode(b.dataset.mode)));
  document.getElementById('inc').addEventListener('click',()=>{if(vehicles<8){vehicles++;document.getElementById('vc').textContent=vehicles;render();}});
  document.getElementById('dec').addEventListener('click',()=>{if(vehicles>2){vehicles--;document.getElementById('vc').textContent=vehicles;render();}});

  render();

  // FAQ
  const _faqs=[
    ['¿Cuántas veces puedo lavar al mes?','Las que quieras. Todos los planes incluyen lavados ilimitados.'],
    ['¿Puedo cambiar de plan después?','Sí, cuando quieras desde tu portal, sin penalidad.'],
    ['¿Cómo cancelo?','En un clic. Sin contrato ni penalidad; disfrutas hasta el fin de tu ciclo.'],
    ['¿La membresía es por auto o por persona?','Por auto. Si tienes varios, revisa el plan Multi-Vehículo.']
  ];
  const _fc=document.getElementById('faq2');
  if(_fc){
    _fc.innerHTML=_faqs.map(([q,a])=>'<div class="q2"><button>'+q+'<span class="cx">+</span></button><div class="ax"><p>'+a+'</p></div></div>').join('');
    _fc.querySelectorAll('.q2 button').forEach(b=>b.addEventListener('click',()=>{
      const q=b.parentElement, ax=q.querySelector('.ax'); const op=q.classList.toggle('open');
      ax.style.maxHeight=op?ax.scrollHeight+'px':0;
    }));
  }
</script>
</body>
</html>
